    <!-- ====================================================================
         Project metadata (required for Maven Central publication)
         ==================================================================== -->

    <name>TigerVNC Java (Oculix fork)</name>
    <description>
        A standalone Maven distribution of the TigerVNC Java viewer, forked
        from RaiMan/sikulix2tigervnc (archived) and maintained as a GPLv2
        dependency for the Oculix visual automation framework.  Provides
        com.tigervnc.* (RFB protocol, decoders, network, RDR, VNC viewer) and
        com.sikulix.vnc.* (thin Java wrappers: VNCClient, VNCFrameBuffer,
        VNCClipboard, XKeySym, security helpers).
    </description>
    <url>https://github.com/oculix-org/tigervnc-java-oculix</url>
    <inceptionYear>2026</inceptionYear>

